{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "MApper desktop capabilities: spawn the backend sidecar + show error dialogs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/mapper-backend", "sidecar": true }
      ]
    }
  ]
}
