{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MApper",
  "version": "0.1.1",
  "identifier": "com.leonardoferhati.mapper",
  "build": {
    "frontendDist": "../mapper-frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix mapper-frontend run dev:desktop",
    "beforeBuildCommand": "npm --prefix mapper-frontend run build:desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MApper",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "visible": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "resources": ["resources/mapper-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
